{
  "name": "@vibes/electron-app",
  "version": "0.1.0",
  "private": true,
  "main": "dist-electron/main/main.cjs",
  "scripts": {
    "dev": "concurrently -k -n vite,main \"vite\" \"npm run dev:main\"",
    "dev:main": "npm run build:main && node scripts/launch-electron.cjs",
    "build:main": "esbuild src/main/main.ts src/main/preload.ts --bundle --platform=node --target=node20 --format=cjs --external:electron --external:electron-updater --outdir=dist-electron/main --out-extension:.js=.cjs",
    "build:renderer": "vite build",
    "build": "npm run build:main && npm run build:renderer",
    "start": "electron .",
    "dist": "npm run build && electron-builder --win --x64",
    "typecheck": "tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.renderer.json --noEmit"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "@vibes/shared": "*",
    "electron-updater": "^6.3.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.16.0",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.2",
    "concurrently": "^9.0.1",
    "cross-env": "^7.0.3",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.7",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.8"
  },
  "build": {
    "extends": null
  }
}
